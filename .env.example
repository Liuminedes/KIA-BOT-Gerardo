# ─────────────────────────────────────────────
#  KIA BOT GERARDO — Variables de entorno
#  Copia este archivo como .env y completa los valores
#  NUNCA subas .env a GitHub
# ─────────────────────────────────────────────

# Servidor
PORT=3000
NODE_ENV=development

# Meta / WhatsApp Cloud API
META_VERIFY_TOKEN=kia_bot_bryan_verify_secret   # Token que tú inventas para verificar el webhook en Meta
META_ACCESS_TOKEN=                               # Token EAA... generado en Meta for Developers
META_PHONE_NUMBER_ID=1066573786537104            # ID del número de WhatsApp Business
META_API_VERSION=v22.0

# Redis (Railway genera esta URL automáticamente)
REDIS_URL=redis://localhost:6379

# Número del asesor (Bryan) — para notificaciones de handoff
# Formato internacional sin + : 573001234567
ADVISOR_PHONE=
